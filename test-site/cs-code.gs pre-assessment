    // Calculate percentage, guarding against dividing by zero (NaN)
    const percentageNum = totalQuestions > 0 ? Math.round((score / totalQuestions) * 100) : 0;

    // --- 4. PROFICIENCY SCALE LOGIC ---
    let proficiency = "1.0 Beginner";
    if (percentageNum >= 90) {
        proficiency = "4.0 Architect";
    } else if (percentageNum >= 80) {
        proficiency = "3.0 Practitioner";
    } else if (percentageNum >= 70) {
        proficiency = "2.0 Apprentice";
    }

    // --- 5. RECORD TO SHEET (10 COLUMNS) ---
    // Make sure your Google Sheet has 10 header columns now (Timestamp, Email, Last, First, Class, Chapter, Score, Total, %, Proficiency)
    sheet.appendRow([
      now, 
      data.email || "Unknown", 
      data.lastName || "Unknown", 
      data.firstName || "Unknown", 
      data.studentClass || "Unknown", 
      data.chapter || "Unknown", 
      score, 
      totalQuestions, 
      percentageNum + "%", 
      proficiency
    ]);

    // Send data back to front-end
    return ContentService.createTextOutput(JSON.stringify({
      "result": "success",
      "score": score,
      "total": totalQuestions,
      "percentage": percentageNum,
      "proficiency": proficiency, // Included for the UI
      "feedback": feedback // Contains only the hint, not the answer
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (error) {
    return ContentService.createTextOutput(JSON.stringify({ "result": "error", "message": error.toString() }))
                         .setMimeType(ContentService.MimeType.JSON);
  }
}